rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // GLOBAL HELPERS
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserEmail() {
      return isSignedIn() ? request.auth.token.email.lower() : "";
    }

    // Hardcoded Super Admins
    function isSuperAdmin() {
      let email = getUserEmail();
      return email == "khaingminthant86@gmail.com" || email == "kozerchi@gmail.com";
    }

    // Dynamic Admin Check
    function isAdmin() {
      return isSuperAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/admins/$(getUserEmail()))
      );
    }

    // ===============================================================
    // CATCH-ALL
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // ADMINS
    // ===============================================================
    match /admins/{email} {
      allow get: if isSignedIn() && (getUserEmail() == email.lower() || isAdmin());
      allow list: if isAdmin();
      allow write: if isSuperAdmin();
    }

    // ===============================================================
    // KEYS (LICENSES)
    // ===============================================================
    match /keys/{keyId} {
      // Single key retrieval is always open for the login system
      allow get: if true;
      
      // Full access for admins
      allow read, write: if isAdmin();
      
      // User Level Operations
      // 1. Claiming a key
      allow update: if (
        resource.data.isUsed == false &&
        request.resource.data.isUsed == true &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'claimedBy', 'claimedAt', 'isUsed', 'expiresAt'])
      );

      // 2. Monitoring their own key
      allow read: if (resource.data.claimedBy == request.auth.uid && request.auth != null) || (resource.data.isUsed == true);
    }

    // ===============================================================
    // SYSTEM PATHS
    // ===============================================================
    match /test/connection {
      allow read: if true;
    }

    match /api_logs/{logId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
